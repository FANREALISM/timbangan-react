{
  "name": "timbangan-react",
  "private": true,
  "version": "1.0.0",
  "description": "Aplikasi Timbangan Digital Desktop",
  "author": {
    "name": "Affan",
    "email": "affan@example.com"
  },
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server:dev": "npm run dev --prefix server",
    "electron:start": "cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently \"npm run dev\" \"npm run server:dev\" \"wait-on http://localhost:5173 --delay 1000 && npm run electron:start\"",
    "electron:build": "npm run build && npx electron-builder",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:open": "npx cap open android",
    "dev:all": "concurrently \"npm run dev\" \"npm run server:dev\""
  },
  "build": {
    "appId": "com.tconnect.app",
    "productName": "Tconnect_V4.0",
    "copyright": "Copyright © 2024 Affan",
    "removePackageScripts": false,
    "asar": true,
    "asarUnpack": [
      "server",
      "config.ini",
      "timbangan.db"
    ],
    "compression": "maximum",
    "npmRebuild": false,
    "directories": {
      "output": "dist-prod"
    },
    "files": [
      "dist",
      "main.cjs",
      "preload.cjs",
      "package.json",
      "server",
      "config.ini",
      "timbangan.db"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tconnect_V4.0"
    }
  },
  "dependencies": {
    "@awesome-cordova-plugins/bluetooth-serial": "^8.1.0",
    "@capacitor-community/bluetooth-le": "^8.1.0",
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6",
    "cors": "^2.8.5",
    "escpos": "^3.0.0-alpha.6",
    "escpos-serialport": "^3.0.0-alpha.4",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "ini": "^4.1.1",
    "jeep-sqlite": "^2.8.0",
    "lucide-react": "^0.284.0",
    "mysql2": "^3.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serialport": "^13.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "web-serial-polyfill": "^1.0.15"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^40.6.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "vite": "^4.4.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^8.0.5"
  }
}
